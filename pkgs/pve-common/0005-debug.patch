---
 src/PVE/Network.pm | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/src/PVE/Network.pm b/src/PVE/Network.pm
index a004c04..4496638 100644
--- a/PVE/Network.pm
+++ b/PVE/Network.pm
@@ -201,6 +201,9 @@ sub iface_create :prototype($$@) {
 
 sub iface_set :prototype($@) {
     my ($iface, @opts) = @_;
+    print "TEST " . "$iface" . " " . "\n";
+    print join(", ", @opts);
+    sleep 120;
     run_command(['/sbin/ip', 'link', 'set', $iface, @opts], noerr => 1)
 	== 0 or die "failed to set interface options for '$iface' (".join(' ', @opts).")\n";
     return;
@@ -210,6 +213,7 @@ sub iface_set :prototype($@) {
 sub iface_set_master :prototype($$) {
     my ($iface, $master) = @_;
     if (defined($master)) {
+	print "TEST " . "$iface" . " " . "$master " . "\n";
 	eval { iface_set($iface, 'master', $master) };
 	die "can't enslave '$iface' to '$master'\n" if $@;
     } else {
